# ====== 刃客坊认证服务 - 环境变量配置 ======
# 复制此文件为 .env 并填入实际值
# 在服务器上: export IHUDI_VOICE_ACCOUNT=xxx

# ---- 互亿无线 语音验证码 (必填) ----
# 账号ID（在互亿无线控制台获取）
IHUDI_VOICE_ACCOUNT=你的互亿无线账号ID
# API密钥（在互亿无线控制中心 -> 开发设置）
IHUDI_VOICE_APIKEY=你的互亿无线APIKey

# ---- JWT/Token 配置 (可选) ----
# 登录token的签名密钥（随机字符串，改了之后所有用户需要重新登录）
AUTH_JWT_SECRET=rkf-secret-change-me-to-random-string-2024
# Token有效期（小时），默认168=7天
AUTH_JWT_EXPIRY=168

# ---- 服务配置 (可选) ----
PORT=5000
HOST=0.0.0.0
